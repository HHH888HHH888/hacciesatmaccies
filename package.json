{
  "name": "haxax",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Haxax — AI mining tenement intelligence platform for Western Australia",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",

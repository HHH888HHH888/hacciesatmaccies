# ============================================================
# Haxax — local configuration & secrets
# Copy this file to ".env" and fill in. ".env" is git-ignored and
# is read ONLY by the server (server/index.ts) — keys never reach
# the browser. Do NOT paste keys into chat; if you ever do, rotate.
# ============================================================

# Data API port. Default 8787.
# IMPORTANT: do NOT set the generic PORT var — the web dev server claims that.
HAXAX_API_PORT=8787

# ---- Access lock (server-side auth) ----
# Site gate password (unlocks the account screen), then per-account passwords.
# Change these to your own values. Sessions last 12h.
HAXAX_GATE_PASSWORD=haxax888
HAXAX_ADMIN_PASSWORD=haig888
HAXAX_GUEST_PASSWORD=haxax888
# Secret used to sign sessions. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# If unset, a random one is used per boot (sessions drop on restart).
HAXAX_SESSION_SECRET=change-me-to-a-long-random-string

# ---- Optional: real AI research notes (replaces the templated note) ----
# Generated server-side from the real register facts.
# Recommended provider: Anthropic Claude.
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# Or MiniMax:
# AI_PROVIDER=minimax
# MINIMAX_API_KEY=xxxxxxxx

# ---- Optional: news / announcement enrichment for the activity feed ----
# BRAVE_API_KEY=xxxxxxxx
